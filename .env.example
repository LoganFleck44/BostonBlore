# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the Boston Blore coaching site
# Copy to `.env` for local dev. In production, set these in Vercel → Settings →
# Environment Variables. Never commit the real `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──
# Local dev: a SQLite file.
DATABASE_URL="file:./dev.db"
# Production (Turso): the libSQL URL + auth token from the Turso dashboard, e.g.
#   DATABASE_URL="libsql://bostonblore-<org>.turso.io"
#   DATABASE_AUTH_TOKEN="<turso auth token>"
DATABASE_AUTH_TOKEN=""

# ── Auth (NextAuth) ──
# Generate a strong secret with:  openssl rand -base64 32
AUTH_SECRET="change-me"
# The site's canonical URL. Local: http://localhost:3000
# Production: https://bostonblore.com
NEXTAUTH_URL="http://localhost:3000"

# ── Contact form email (Resend) ──
# Create a free account at https://resend.com and paste the API key.
RESEND_API_KEY=""
# Where enquiries are delivered.
CONTACT_TO_EMAIL="bostonblore@icloud.com"
# Reply-to address for normal client conversations.
CONTACT_REPLY_TO_EMAIL="bostonblore@icloud.com"
# From address. This must be on a domain you control and verify in Resend.
# You cannot send from an @icloud.com address through Resend.
CONTACT_FROM_EMAIL="Boston Blore <hello@bostonblore.com>"

# ── Production seed (npm run seed:prod) — not needed at runtime ──
# TRAINER_EMAIL="boston@bostonblore.com"
# TRAINER_NAME="Boston Blore"
# TRAINER_PASSWORD="set-a-strong-password"
